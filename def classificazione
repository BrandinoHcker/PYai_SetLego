from google.colab import files
import tf_keras as keras  # Importare tf-keras: una versione di Keras compatibile con i modelli .h5
from tf_keras.models import load_model  # Importare la funzione load_model da tf_keras, che ci permette di aprire il modello
from PIL import Image, ImageOps  # Installare pillow invece di PIL
import numpy as np

def classificazione(modello, labels):
  path = files.upload()
  path = list(path.keys())[0]
  image=Image.open(path)

  np.set_printoptions(suppress=True)
  model = load_model(modello, compile=False)
  class_names = open(labels, "r").readlines()

  data = np.ndarray(shape=(1, 224, 224, 3), dtype=np.float32)


  size = (224, 224)
  image = ImageOps.fit(image, size, Image.Resampling.LANCZOS)
  image_array = np.asarray(image)
  normalized_image_array = (image_array.astype(np.float32) / 127.5) - 1
  data[0] = normalized_image_array

  prediction = model.predict(data)
  print(prediction)
  index = np.argmax(prediction)
  class_name = class_names[index]
  confidence_score = prediction[0][index]

  print("Class:", class_name[2:], end="")
  print("Confidence Score:", confidence_score)
  return class_name[2:].strip()
